# =============================================
# Variables de Entorno — ViajeJusto
# Copia este archivo como .env y rellena los valores
# =============================================

# ─── Frontend (Vite) ────────────────────
VITE_SUPABASE_URL=https://tu-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
VITE_OTP_SERVER_URL=https://tu-otp-server-url.com

# ─── OTP Server (server.js) ─────────────
# Estas se configuran directamente en otp-package/server.js
# En producción, migrar a variables de entorno:
#
# SUPABASE_URL=https://tu-supabase-url.supabase.co
# SUPABASE_SERVICE_KEY=tu_service_role_key
# EVOLUTION_API_URL=https://tu-evolution-api/message/sendText/NombreInstancia
# EVOLUTION_API_KEY=tu_evolution_api_key
# RESEND_API_KEY=tu_resend_api_key
# PORT=3002
